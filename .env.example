# Optional Graphormer integration test settings.
# Enable only when a local Graphormer checkout and fairseq environment are ready.

GRAPHORMER_RUN_INTEGRATION=0
GRAPHORMER_REPO_PATH=/absolute/path/to/Graphormer
GRAPHORMER_DATASET_NAME=pcqm4m
GRAPHORMER_DATASET_SOURCE=ogb
GRAPHORMER_PRETRAINED_MODEL_NAME=pcqm4mv1_graphormer_base

# Optional overrides.
GRAPHORMER_TASK=graph_prediction
GRAPHORMER_ARCH=graphormer_base
GRAPHORMER_NUM_CLASSES=1
GRAPHORMER_BATCH_SIZE=64
GRAPHORMER_SPLIT=valid
GRAPHORMER_SEED=1
GRAPHORMER_NUM_WORKERS=0
GRAPHORMER_CRITERION=l1_loss
GRAPHORMER_LOAD_OUTPUT_LAYER=1
GRAPHORMER_METRIC=
GRAPHORMER_SAVE_DIR=

# Optional DiG integration test settings.
# Enable only when a local Graphormer checkout and protein-ligand workflow data are ready.

DIG_RUN_INTEGRATION=0
DIG_REPO_PATH=/absolute/path/to/Graphormer
DIG_WORKFLOW=protein_ligand_single_datapoint
DIG_PDBID=1a2k
DIG_SAMPLE_COUNT=5

# Optional DiG protein system integration test settings.
# Enable only when a local Graphormer checkout and protein workflow data are ready.

DIG_PROTEIN_RUN_INTEGRATION=0
DIG_PROTEIN_REPO_PATH=/absolute/path/to/Graphormer
DIG_PROTEIN_PDBID=6lu7
DIG_PROTEIN_SAMPLE_COUNT=3
DIG_PROTEIN_CHECKPOINT_PATH=
DIG_PROTEIN_FEATURE_PATH=
DIG_PROTEIN_FASTA_PATH=
DIG_PROTEIN_OUTPUT_PREFIX=
DIG_PROTEIN_USE_GPU=1
DIG_PROTEIN_USE_TQDM=1

# Optional DiG equilibrium integration test settings.
# Enable only when a local Graphormer checkout and catalyst-adsorption workflow data are ready.

DIG_EQUILIBRIUM_RUN_INTEGRATION=0
DIG_EQUILIBRIUM_REPO_PATH=/absolute/path/to/Graphormer
DIG_EQUILIBRIUM_NUM_GPUS=1
DIG_EQUILIBRIUM_BATCH_SIZE_PER_GPU=2
DIG_EQUILIBRIUM_SAVE_DIR=/tmp/dig-density
DIG_EQUILIBRIUM_HEIGHT_INDICES=0,1,2

# Optional DiG property-guided integration test settings.
# Enable only when a local Graphormer checkout and property-guided workflow data are ready.

DIG_PROPERTY_RUN_INTEGRATION=0
DIG_PROPERTY_REPO_PATH=/absolute/path/to/Graphormer
DIG_PROPERTY_NUM_GPUS=1
DIG_PROPERTY_BATCH_SIZE_PER_GPU=2
DIG_PROPERTY_SAVE_DIR=/tmp/dig-property-guided
DIG_PROPERTY_NUM_ATOMS=16
DIG_PROPERTY_TARGET_BANDGAP=1.5

